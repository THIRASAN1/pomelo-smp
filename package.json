{
  "name": "pomelo-smp",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --env-file-if-exists=.env ./node_modules/astro/astro.js dev",
    "check": "node --env-file-if-exists=.env ./node_modules/astro/astro.js check",
    "build": "node --env-file-if-exists=.env ./node_modules/astro/astro.js check && node --env-file-if-exists=.env ./node_modules/astro/astro.js build",
    "preview": "node --env-file-if-exists=.env ./node_modules/astro/astro.js preview",
    "start": "node --env-file-if-exists=.env ./dist/server/entry.mjs",
    "astro": "astro",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=.env --import tsx/esm scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "admin:hash": "node --import tsx/esm scripts/hash-password.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/node": "^8.3.4",
    "@astrojs/tailwind": "^5.1.2",
    "@libsql/client": "^0.14.0",
    "astro": "^4.16.7",
    "drizzle-orm": "^0.36.4",
    "pino": "^9.5.0",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
