# ─── Runtime ──────────────────────────────────────────────
NODE_ENV=development
PORT=4321
HOST=0.0.0.0
LOG_LEVEL=info           # trace | debug | info | warn | error | fatal

# ─── Security ─────────────────────────────────────────────
# Comma-separated list of origins allowed to POST to /api/*
# In production, set this to your public site origin, e.g. https://pomelosmp.net
ALLOWED_ORIGINS=http://localhost:4321

# Secret used for signing/verifying internal tokens (>=32 chars).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=change-me-with-a-long-random-hex-string-at-least-32-chars

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=file:./data/pomelo.db

# ─── Admin panel ──────────────────────────────────────────
# Leave both blank to disable /admin/* and /api/admin/* routes entirely.
# Generate the hash with:  npm run admin:hash -- "your-strong-password"
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
SESSION_TTL_HOURS=24

# ─── Minecraft server ─────────────────────────────────────
MC_HOST=play.pomelosmp.net
MC_PORT=25565

# ─── Discord (optional – for whitelist notifications) ─────
# Create: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# ─── Rate limiting ────────────────────────────────────────
RATE_LIMIT_WHITELIST_PER_HOUR=3      # max whitelist submissions / IP / hour
RATE_LIMIT_API_PER_MINUTE=60         # max API requests / IP / minute
