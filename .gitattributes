# Handle line endings automatically for files detected as text
# and leave binary files untouched.
* text=auto eol=lf

# Explicit rules for common source files
*.astro     text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.svg       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Binary files
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
