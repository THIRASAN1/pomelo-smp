---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — ไม่พบหน้าที่คุณต้องการ · PomeloSMP">
  <section class="section">
    <div class="container-app">
      <div class="mx-auto max-w-xl text-center">
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-pomelo-600">
          error / 404
        </p>
        <h1 class="mt-4 font-display text-5xl font-bold leading-tight text-ink-900 sm:text-7xl">
          หน้านี้<span class="text-pomelo-600">หายไป</span>เหมือนหินหายากในถ้ำ
        </h1>
        <p class="mt-5 text-pretty text-base text-ink-500">
          ลิงก์ที่คุณพยายามเข้าไม่มีอยู่ หรืออาจถูกย้ายไปแล้ว
          ลองกลับหน้าแรก หรือทักทีมงานใน Discord ก็ได้นะ
        </p>

        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a href="/" class="btn-primary">
            ← กลับหน้าแรก
          </a>
          <a href="/#apply" class="btn-outline">
            ขอเข้าเล่น
          </a>
          <a
            href="https://discord.gg/pomelosmp"
            target="_blank"
            rel="noopener"
            class="btn-ghost"
          >
            ถาม Discord
          </a>
        </div>

        <!-- Decorative SVG — pomelo half with a bite taken out -->
        <svg
          viewBox="0 0 240 160"
          class="mx-auto mt-14 h-32 w-auto text-pomelo-400/60"
          aria-hidden="true"
        >
          <defs>
            <radialGradient id="p404" cx="50%" cy="45%" r="60%">
              <stop offset="0%" stop-color="rgb(253 186 116)" />
              <stop offset="100%" stop-color="rgb(234 88 12)" />
            </radialGradient>
          </defs>
          <circle cx="120" cy="80" r="58" fill="url(#p404)" opacity="0.85" />
          <path d="M120 22a58 58 0 0 0-58 58 58 58 0 0 0 58 58 58 58 0 0 0 58-58c-20-2-42 20-58 20s-38-22-58-20A58 58 0 0 1 120 22z"
            fill="rgb(255 247 237)" opacity="0.6" />
          <circle cx="98" cy="64" r="5" fill="rgb(190 18 60)" opacity="0.6" />
          <circle cx="140" cy="88" r="5" fill="rgb(190 18 60)" opacity="0.6" />
          <circle cx="112" cy="104" r="5" fill="rgb(190 18 60)" opacity="0.6" />
        </svg>
      </div>
    </div>
  </section>
</Layout>
