---
import Logo from './Logo.astro';
const year = new Date().getFullYear();
---

<footer class="border-t border-ink-900/5 bg-white/40 backdrop-blur">
  <div class="container-app grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <Logo />
      <p class="mt-3 max-w-xs text-sm leading-relaxed text-ink-500">
        เซิร์ฟเวอร์ Minecraft SMP สายชิลล์ — สดชื่นอบอุ่นเหมือนกลิ่นส้มโอยามเช้า 🍊
      </p>
    </div>

    <div>
      <h4 class="text-sm font-semibold text-ink-900">เซิร์ฟเวอร์</h4>
      <ul class="mt-3 space-y-2 text-sm text-ink-500">
        <li><a class="hover:text-pomelo-600" href="#join">วิธีเข้าเล่น</a></li>
        <li><a class="hover:text-pomelo-600" href="#rules">กติกา</a></li>
        <li><a class="hover:text-pomelo-600" href="#features">ไฮไลท์</a></li>
        <li><a class="hover:text-pomelo-600" href="#faq">คำถามที่พบบ่อย</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-semibold text-ink-900">ชุมชน</h4>
      <ul class="mt-3 space-y-2 text-sm text-ink-500">
        <li><a class="hover:text-pomelo-600" href="https://discord.gg/pomelosmp" target="_blank" rel="noopener">Discord</a></li>
        <li><a class="hover:text-pomelo-600" href="#" target="_blank" rel="noopener">แผนที่ออนไลน์</a></li>
        <li><a class="hover:text-pomelo-600" href="#" target="_blank" rel="noopener">ร้านค้า</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-semibold text-ink-900">IP เซิร์ฟเวอร์</h4>
      <div class="mt-3 rounded-xl border border-ink-900/10 bg-cream-50 p-3 font-mono text-sm">
        play.pomelosmp.net
      </div>
      <p class="mt-2 text-xs text-ink-500">รองรับ Java Edition 1.21.x</p>
    </div>
  </div>

  <div class="border-t border-ink-900/5">
    <div class="container-app flex flex-col items-center justify-between gap-3 py-5 text-xs text-ink-500 sm:flex-row">
      <p>© {year} PomeloSMP · Not affiliated with Mojang AB.</p>
      <p class="font-mono">made with 🍊 &amp; Astro</p>
    </div>
  </div>
</footer>
