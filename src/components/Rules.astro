---
const rules = [
  { t: 'เคารพกันและกัน', d: 'ไม่เหยียด ไม่บูลลี่ ไม่พูดจารุนแรง ภาษาหยาบเล็กน้อยรับได้' },
  { t: 'ห้าม Griefing', d: 'ไม่ทำลายของคนอื่น ไม่เผาบ้าน ไม่ขโมยของใน chest' },
  { t: 'ห้ามใช้ Cheat / Hack', d: 'X-Ray, Fly, Auto-clicker, Duplication รวมถึง mod ที่ให้เปรียบ' },
  { t: 'PvP ต้องยินยอม', d: 'สู้กันได้เฉพาะในเขต arena หรือทั้งสองฝ่ายยินยอม' },
  { t: 'รักษาโลก', d: 'ไม่ขุด strip-mine กลางลาน ไม่ทิ้ง floating trees ไว้รกหูรกตา' },
  { t: 'สนุกก่อนเสมอ', d: 'ถ้ากฎข้อไหนทำให้ไม่สนุก ทักทีมงานได้ เราปรับให้ทุกซีซั่น' },
];
---

<section id="rules" class="section bg-cream-100/60">
  <div class="container-app">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">กติกาชุมชน</p>
        <h2 class="mt-3 text-balance text-4xl font-bold leading-tight sm:text-5xl">
          กติกาสั้น ๆ<br />
          ที่ทำให้<span class="text-pomelo-600">อยู่ด้วยกันได้นาน ๆ</span>
        </h2>
        <p class="mt-4 text-ink-500">
          เราเชื่อในกติกาที่เข้าใจง่าย ไม่ยาว ไม่หยุมหยิม ขอแค่มี common sense ก็อยู่ได้อย่างสบายใจ
        </p>
      </div>

      <ul class="grid gap-3 sm:grid-cols-2">
        {
          rules.map((r, i) => (
            <li class="rounded-2xl border border-ink-900/5 bg-white/80 p-5 backdrop-blur transition hover:border-pomelo-500/30">
              <div class="flex items-center gap-3">
                <span class="flex h-7 w-7 items-center justify-center rounded-full bg-pomelo-100 font-mono text-xs font-semibold text-pomelo-700">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <h3 class="font-display text-base font-semibold">{r.t}</h3>
              </div>
              <p class="mt-2 pl-10 text-sm leading-relaxed text-ink-500">{r.d}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
