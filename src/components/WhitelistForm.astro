---
// Accessible whitelist-application form. Posts JSON to /api/whitelist and
// renders validation/API errors inline.
---

<section id="apply" class="section">
  <div class="container-app">
    <div class="mx-auto max-w-2xl">
      <div class="text-center">
        <p class="eyebrow">ขอเข้าเซิร์ฟ</p>
        <h2 class="mt-3 text-balance text-4xl font-bold leading-tight sm:text-5xl">
          ส่งฟอร์มขอเข้า<span class="text-pomelo-600">ในไม่กี่นาที</span>
        </h2>
        <p class="mt-4 text-ink-500">
          ทีมงานอ่านทุกใบสมัครจริง ๆ จะพยายามตอบกลับภายใน 24 ชม.
        </p>
      </div>

      <form
        id="wl-form"
        class="mt-10 card space-y-5"
        novalidate
        autocomplete="off"
      >
        <!-- Honeypot: hidden from humans, bots happily fill it. -->
        <div class="sr-only" aria-hidden="true">
          <label>Website<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <label class="block">
            <span class="text-sm font-medium text-ink-700">Minecraft username</span>
            <input
              required
              name="minecraftUsername"
              minlength="3"
              maxlength="16"
              pattern="[A-Za-z0-9_]{3,16}"
              placeholder="Steve"
              class="mt-1.5 w-full rounded-xl border border-ink-900/10 bg-white px-3 py-2 font-mono text-sm outline-none ring-pomelo-500/30 focus:border-pomelo-500 focus:ring-2"
            />
            <span data-error-for="minecraftUsername" class="mt-1 block text-xs text-flesh-500"></span>
          </label>

          <label class="block">
            <span class="text-sm font-medium text-ink-700">Discord handle</span>
            <input
              required
              name="discordHandle"
              placeholder="pomelo.smp"
              class="mt-1.5 w-full rounded-xl border border-ink-900/10 bg-white px-3 py-2 font-mono text-sm outline-none ring-pomelo-500/30 focus:border-pomelo-500 focus:ring-2"
            />
            <span data-error-for="discordHandle" class="mt-1 block text-xs text-flesh-500"></span>
          </label>
        </div>

        <div class="grid gap-4 sm:grid-cols-[100px_1fr]">
          <label class="block">
            <span class="text-sm font-medium text-ink-700">อายุ</span>
            <input
              required
              name="age"
              type="number"
              min="10"
              max="99"
              class="mt-1.5 w-full rounded-xl border border-ink-900/10 bg-white px-3 py-2 text-sm outline-none ring-pomelo-500/30 focus:border-pomelo-500 focus:ring-2"
            />
            <span data-error-for="age" class="mt-1 block text-xs text-flesh-500"></span>
          </label>

          <label class="block">
            <span class="text-sm font-medium text-ink-700">รู้จักเซิร์ฟจากไหน <span class="text-ink-300">(ไม่บังคับ)</span></span>
            <input
              name="referrer"
              maxlength="50"
              placeholder="เพื่อนแนะนำ / TikTok / YouTube"
              class="mt-1.5 w-full rounded-xl border border-ink-900/10 bg-white px-3 py-2 text-sm outline-none ring-pomelo-500/30 focus:border-pomelo-500 focus:ring-2"
            />
          </label>
        </div>

        <label class="block">
          <span class="text-sm font-medium text-ink-700">
            อยากเล่นกับ PomeloSMP เพราะอะไร?
          </span>
          <textarea
            required
            name="whyJoin"
            rows="4"
            minlength="20"
            maxlength="1000"
            placeholder="เล่าถึงสไตล์การเล่น, โปรเจกต์ที่อยากทำ, หรืออะไรก็ได้ที่อยากให้ทีมงานรู้..."
            class="mt-1.5 w-full rounded-xl border border-ink-900/10 bg-white px-3 py-2 text-sm leading-relaxed outline-none ring-pomelo-500/30 focus:border-pomelo-500 focus:ring-2"
          ></textarea>
          <span data-error-for="whyJoin" class="mt-1 block text-xs text-flesh-500"></span>
        </label>

        <div class="flex flex-col items-start gap-3 sm:flex-row sm:items-center sm:justify-between">
          <p class="text-xs text-ink-500">
            การส่งฟอร์มถือว่ายอมรับ <a href="#rules" class="underline underline-offset-2 hover:text-pomelo-600">กติกา</a> ของเซิร์ฟ
          </p>
          <button type="submit" class="btn-primary" data-submit>
            <span data-submit-label>ส่งใบสมัคร</span>
            <svg viewBox="0 0 20 20" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 10h12m0 0-4-4m4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>

        <div
          id="wl-result"
          class="hidden rounded-xl border p-4 text-sm"
          role="status"
          aria-live="polite"
        ></div>
      </form>
    </div>
  </div>
</section>

<script>
  type FieldName = 'minecraftUsername' | 'discordHandle' | 'age' | 'whyJoin' | 'referrer' | 'website';
  type ApiError = {
    error: {
      code: string;
      message: string;
      details?: Array<{ path: (string | number)[]; message: string }>;
      requestId?: string;
    };
  };
  type ApiSuccess = {
    data: { id: string; status: string; message: string };
  };

  const form = document.querySelector<HTMLFormElement>('#wl-form');
  const result = document.querySelector<HTMLElement>('#wl-result');
  const submitBtn = document.querySelector<HTMLButtonElement>('[data-submit]');
  const submitLabel = document.querySelector<HTMLElement>('[data-submit-label]');

  function clearErrors() {
    document.querySelectorAll<HTMLElement>('[data-error-for]').forEach((el) => (el.textContent = ''));
    result?.classList.add('hidden');
    result?.classList.remove('border-flesh-500/40', 'bg-flesh-50', 'text-flesh-500', 'border-leaf-500/40', 'bg-leaf-50', 'text-leaf-600');
  }

  function setFieldError(name: FieldName, msg: string) {
    const el = document.querySelector<HTMLElement>(`[data-error-for="${name}"]`);
    if (el) el.textContent = msg;
  }

  function showResult(kind: 'success' | 'error', html: string) {
    if (!result) return;
    result.innerHTML = html;
    result.classList.remove('hidden');
    if (kind === 'success') {
      result.classList.add('border-leaf-500/40', 'bg-leaf-50', 'text-leaf-600');
    } else {
      result.classList.add('border-flesh-500/40', 'bg-flesh-50', 'text-flesh-500');
    }
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn || !submitLabel) return;
    clearErrors();

    const fd = new FormData(form);
    const payload = {
      minecraftUsername: String(fd.get('minecraftUsername') ?? '').trim(),
      discordHandle: String(fd.get('discordHandle') ?? '').trim(),
      age: Number(fd.get('age') ?? 0),
      whyJoin: String(fd.get('whyJoin') ?? '').trim(),
      referrer: String(fd.get('referrer') ?? '').trim() || undefined,
      website: String(fd.get('website') ?? ''),
    };

    submitBtn.disabled = true;
    const prevLabel = submitLabel.textContent;
    submitLabel.textContent = 'กำลังส่ง…';

    try {
      const res = await fetch('/api/whitelist', {
        method: 'POST',
        headers: { 'content-type': 'application/json', accept: 'application/json' },
        body: JSON.stringify(payload),
      });

      if (res.status === 201) {
        const body = (await res.json()) as ApiSuccess;
        form.reset();
        showResult(
          'success',
          `<p class="font-medium">✔ ${body.data.message}</p>
           <p class="mt-1 font-mono text-xs opacity-80">ID: ${body.data.id}</p>`,
        );
        return;
      }

      const err = (await res.json()) as ApiError;
      if (err.error?.details && Array.isArray(err.error.details)) {
        for (const issue of err.error.details) {
          const name = issue.path[0] as FieldName;
          if (name) setFieldError(name, issue.message);
        }
      }
      showResult('error', `<p class="font-medium">${err.error?.message ?? 'ส่งไม่สำเร็จ'}</p>`);
    } catch (err) {
      console.error(err);
      showResult('error', '<p>เชื่อมต่อไม่ได้ ลองใหม่อีกครั้ง</p>');
    } finally {
      submitBtn.disabled = false;
      submitLabel.textContent = prevLabel;
    }
  });
</script>
