---
const features = [
  {
    title: 'Vanilla+ แต่งเบา ๆ',
    desc: 'รักษาความเป็น Minecraft แท้ ๆ เพิ่ม QoL อย่าง Graves, Homes, Warps ให้เล่นสบายขึ้น',
    icon: 'leaf',
  },
  {
    title: 'สังคมคุณภาพ',
    desc: 'ทีมงานคัดผู้เล่นด้วยแบบฟอร์ม Whitelist เน้นคนที่มีใจจริง ไม่โทรลล์ ไม่ดราม่า',
    icon: 'heart',
  },
  {
    title: 'ไม่ Pay-to-Win',
    desc: 'ทุกอย่างหาได้จากการเล่นปกติ ไม่มีการขายไอเทมหรือยศที่ให้เปรียบในเกม',
    icon: 'shield',
  },
  {
    title: 'เศรษฐกิจชุมชน',
    desc: 'ระบบร้านค้าผู้เล่น (Player Shop) และสกุลเงินเบา ๆ ให้พ่อค้าตัวจริงได้ออกแบบร้าน',
    icon: 'coin',
  },
  {
    title: 'อีเวนต์ทุกสัปดาห์',
    desc: 'Build Battle, Drop Party, Boss Hunt และมินิเกมประจำซีซั่นที่ทีมงานจัดอย่างตั้งใจ',
    icon: 'spark',
  },
  {
    title: 'แผนที่ออนไลน์',
    desc: 'Bluemap ส่องทั้งโลกได้แบบสด ๆ เห็นบ้านของเพื่อน ๆ และขอบเขตเมืองที่กำลังเติบโต',
    icon: 'map',
  },
];
---

<section id="features" class="section">
  <div class="container-app">
    <div class="max-w-2xl">
      <p class="eyebrow">ทำไมต้อง PomeloSMP</p>
      <h2 class="mt-3 text-balance text-4xl font-bold leading-tight sm:text-5xl">
        เซิร์ฟเวอร์ที่ทำให้<span class="text-pomelo-600">การเล่นสบายใจ</span>
        คือสิ่งสำคัญที่สุด
      </h2>
      <p class="mt-4 text-ink-500">
        เราเชื่อว่าเซิร์ฟเวอร์ที่ดีไม่ใช่เซิร์ฟเวอร์ที่ใหญ่ที่สุด แต่คือเซิร์ฟเวอร์ที่
        ทำให้คุณอยากกลับมาเล่นทุกวัน
      </p>
    </div>

    <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <article class="card group transition-all duration-300 hover:-translate-y-1 hover:border-pomelo-500/30 hover:shadow-glow">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-pomelo-100 text-pomelo-700 transition group-hover:bg-pomelo-500 group-hover:text-white">
              {f.icon === 'leaf' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
                  <path d="M20 4c0 8-5 13-13 13H4c0-8 5-13 13-13h3Z" stroke-linejoin="round" />
                  <path d="M4 20c2-6 6-10 12-12" stroke-linecap="round" />
                </svg>
              )}
              {f.icon === 'heart' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
                  <path d="M12 20s-7-4.3-7-10a4 4 0 0 1 7-2.6A4 4 0 0 1 19 10c0 5.7-7 10-7 10Z" stroke-linejoin="round" />
                </svg>
              )}
              {f.icon === 'shield' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
                  <path d="M12 3 5 6v6c0 4 3 7 7 9 4-2 7-5 7-9V6l-7-3Z" stroke-linejoin="round" />
                  <path d="m9 12 2 2 4-4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
              {f.icon === 'coin' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
                  <circle cx="12" cy="12" r="8" />
                  <path d="M12 8v8M9 10h4.5a1.5 1.5 0 0 1 0 3H9h5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              )}
              {f.icon === 'spark' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
                  <path d="M12 3v4M12 17v4M3 12h4M17 12h4M6 6l2.5 2.5M15.5 15.5 18 18M6 18l2.5-2.5M15.5 8.5 18 6" stroke-linecap="round" />
                </svg>
              )}
              {f.icon === 'map' && (
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5" aria-hidden="true">
                  <path d="m3 6 6-2 6 2 6-2v14l-6 2-6-2-6 2V6Z" stroke-linejoin="round" />
                  <path d="M9 4v16M15 6v16" />
                </svg>
              )}
            </div>
            <h3 class="mt-4 font-display text-lg font-semibold">{f.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-ink-500">{f.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
