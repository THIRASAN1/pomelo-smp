---
const steps = [
  {
    n: '01',
    title: 'เปิด Minecraft Java 1.21.x',
    desc: 'รองรับเวอร์ชัน 1.21 เป็นต้นไป หากเวอร์ชันใหม่กว่าเกิดปัญหา เข้า Discord มาแจ้งได้เลย',
  },
  {
    n: '02',
    title: 'Add Server → วาง IP',
    desc: 'ใส่ play.pomelosmp.net ลงในช่อง Server Address แล้วกด Done',
  },
  {
    n: '03',
    title: 'กรอกฟอร์ม Whitelist',
    desc: 'กรอกฟอร์มสั้น ๆ ที่ด้านล่างของหน้านี้ (MC name, Discord, อายุ) ทีมงานอ่านและตอบกลับใน Discord ภายใน 24 ชม.',
    href: '#apply',
  },
  {
    n: '04',
    title: 'เริ่มต้นการผจญภัย',
    desc: 'เข้าสู่ spawn เลือกทิศ เดินหา plot แล้วลงหลักปักฐานแบบที่คุณอยากเป็น',
  },
];
---

<section id="join" class="section">
  <div class="container-app">
    <div class="grid gap-12 lg:grid-cols-[1fr_1.4fr]">
      <div>
        <p class="eyebrow">เริ่มเล่นใน 4 ขั้นตอน</p>
        <h2 class="mt-3 text-balance text-4xl font-bold leading-tight sm:text-5xl">
          เข้ามา<span class="text-pomelo-600">เล่นง่าย</span>
          เหมือนปอกส้มโอ
        </h2>
        <p class="mt-4 text-ink-500">
          ใช้เวลาประมาณ 5 นาที คุณก็จะได้ลุยโลกใหม่กับเพื่อนชาว PomeloSMP แล้ว
        </p>

        <div class="mt-8 rounded-2xl border border-ink-900/5 bg-gradient-to-br from-pomelo-50 to-flesh-50 p-6">
          <p class="text-sm font-medium text-ink-700">พร้อมเข้าเล่นแล้ว?</p>
          <p class="mt-1 text-sm text-ink-500">กรอกฟอร์มด้านล่าง ทีมงานอนุมัติภายใน 24 ชม.</p>
          <div class="mt-4 flex flex-wrap gap-2">
            <a href="#apply" class="btn-primary">
              กรอกฟอร์ม
            </a>
            <a
              href="https://discord.gg/pomelosmp"
              target="_blank"
              rel="noopener"
              class="btn-ghost"
            >
              ถาม Discord
            </a>
          </div>
        </div>
      </div>

      <ol class="space-y-3">
        {
          steps.map((s) => {
            const inner = (
              <>
                <div class="shrink-0 font-mono text-xs font-semibold text-pomelo-600">{s.n}</div>
                <div>
                  <h3 class="font-display text-lg font-semibold">{s.title}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-ink-500">{s.desc}</p>
                </div>
              </>
            );
            return s.href ? (
              <li>
                <a
                  href={s.href}
                  class="card flex gap-5 transition hover:border-pomelo-500/30 hover:bg-pomelo-50/40"
                >
                  {inner}
                </a>
              </li>
            ) : (
              <li class="card flex gap-5 transition hover:border-pomelo-500/30">{inner}</li>
            );
          })
        }
      </ol>
    </div>
  </div>
</section>
