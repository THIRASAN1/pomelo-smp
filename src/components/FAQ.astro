---
const faqs = [
  {
    q: 'เล่นได้กับ Bedrock Edition ไหม?',
    a: 'ตอนนี้เปิดเฉพาะ Java Edition เท่านั้น เพราะปลั๊กอินและระบบต่าง ๆ ถูกออกแบบให้เสถียรที่สุดบน Java',
  },
  {
    q: 'ต้องจ่ายเงินไหม?',
    a: 'ฟรี 100% ไม่มี Pay-to-Win เราอยู่ได้ด้วยค่า VPS ที่ทีมงานช่วยกันออก และจะมีช่องทาง donate แบบสมัครใจในอนาคต',
  },
  {
    q: 'Whitelist ใช้เวลานานไหม?',
    a: 'ปกติอนุมัติภายใน 24 ชั่วโมง ทีมงานจะอ่านฟอร์มจริง ๆ ไม่ใช่บอตกดผ่าน',
  },
  {
    q: 'มีการ reset โลกไหม?',
    a: 'Reset เฉพาะ Resource World ทุก 1 เดือน เพื่อให้หาของได้สะดวก ส่วน Survival Main จะเก็บข้ามซีซั่น',
  },
  {
    q: 'มี Mod/Plugin อะไรบ้าง?',
    a: 'GraveStone, Homes, Warps, ChestShop, Dynmap/Bluemap และปลั๊กอิน QoL ที่ไม่กระทบ gameplay หลัก',
  },
];
---

<section id="faq" class="section">
  <div class="container-app">
    <div class="mx-auto max-w-3xl">
      <div class="text-center">
        <p class="eyebrow">คำถามที่พบบ่อย</p>
        <h2 class="mt-3 text-balance text-4xl font-bold leading-tight sm:text-5xl">
          เคลียร์ข้อสงสัยก่อน<span class="text-pomelo-600">กดเข้าเซิร์ฟ</span>
        </h2>
      </div>

      <div class="mt-12 divide-y divide-ink-900/5 overflow-hidden rounded-2xl border border-ink-900/5 bg-white/70 backdrop-blur">
        {
          faqs.map((f, i) => (
            <details class="group" open={i === 0}>
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5 font-display font-semibold text-ink-900 transition hover:bg-cream-100/70">
                <span>{f.q}</span>
                <svg
                  class="h-5 w-5 shrink-0 text-ink-500 transition group-open:rotate-45 group-open:text-pomelo-600"
                  viewBox="0 0 20 20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  aria-hidden="true"
                >
                  <path d="M10 4v12M4 10h12" stroke-linecap="round" />
                </svg>
              </summary>
              <div class="px-5 pb-5 text-sm leading-relaxed text-ink-500">{f.a}</div>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>
